APP_NAME="GGWP Boost"
APP_ENV=production
APP_KEY=REPLACE_WITH_GENERATED_APP_KEY
APP_DEBUG=false
APP_URL=https://www.example.com

STARTUP_VALIDATION_ENABLED=true
STARTUP_VALIDATE_IN_CONSOLE=true
STARTUP_REQUIRE_TRUSTED_PROXIES=true
TRUSTED_PROXIES=REPLACE_WITH_PROXY_CIDRS

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=info
SECURITY_LOG_LEVEL=warning
PAYMENT_LOG_LEVEL=info
WEBHOOK_LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=REPLACE_WITH_DATABASE_HOST
DB_PORT=3306
DB_DATABASE=REPLACE_WITH_DATABASE_NAME
DB_USERNAME=REPLACE_WITH_DATABASE_USER
DB_PASSWORD=REPLACE_WITH_DATABASE_PASSWORD

SESSION_DRIVER=database
SESSION_CONNECTION=mysql
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
DB_CACHE_CONNECTION=mysql
QUEUE_CONNECTION=database
DB_QUEUE_CONNECTION=mysql
DB_QUEUE_BATCHING_CONNECTION=mysql
DB_QUEUE_FAILED_CONNECTION=mysql
QUEUE_FAILED_DRIVER=database-uuids

FILESYSTEM_DISK=public

STRIPE_ENABLED=true
STRIPE_KEY=REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET=REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET

CRYPTOMUS_ENABLED=true
CRYPTOMUS_MERCHANT_ID=REPLACE_WITH_CRYPTOMUS_MERCHANT_ID
CRYPTOMUS_API_KEY=REPLACE_WITH_CRYPTOMUS_API_KEY
CRYPTOMUS_BASE_URL=https://api.cryptomus.com
CRYPTOMUS_ALLOWED_HOSTS=api.cryptomus.com
CRYPTOMUS_TIMEOUT=15
CRYPTOMUS_INVOICE_LIFETIME=3600

ANALYTICS_GOOGLE_MEASUREMENT_ID=
ANALYTICS_POSTHOG_KEY=
ANALYTICS_POSTHOG_HOST=https://us.i.posthog.com
ANALYTICS_POSTHOG_DEFAULTS=2026-01-30

GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
DISCORD_CLIENT_ID=REPLACE_WITH_DISCORD_CLIENT_ID
DISCORD_CLIENT_SECRET=REPLACE_WITH_DISCORD_CLIENT_SECRET
DISCORD_REDIRECT_URI="${APP_URL}/auth/discord/callback"

BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=REPLACE_WITH_PUSHER_APP_ID
PUSHER_APP_KEY=REPLACE_WITH_PUSHER_APP_KEY
PUSHER_APP_SECRET=REPLACE_WITH_PUSHER_APP_SECRET
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=REPLACE_WITH_WEBSOCKET_HOST
PUSHER_PORT=443
PUSHER_SCHEME=https
WEBSOCKETS_ALLOWED_ORIGINS=https://www.example.com
WEBSOCKETS_ENABLE_STATISTICS=false
LARAVEL_WEBSOCKETS_PATH=laravel-websockets

MAIL_MAILER=smtp
MAIL_HOST=REPLACE_WITH_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=REPLACE_WITH_SMTP_USER
MAIL_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
MAIL_FROM_ADDRESS=support@example.com
MAIL_FROM_NAME="${APP_NAME}"

SUPPORT_EMAIL=support@example.com
SUPPORT_PHONE=
COMMUNITY_DISCORD_URL=
SOCIAL_DISCORD_URL=
SOCIAL_FACEBOOK_URL=
SOCIAL_INSTAGRAM_URL=
SOCIAL_TWITTER_URL=
SOCIAL_TWITCH_URL=
SOCIAL_YOUTUBE_URL=
FOOTER_LEGAL_NAME="GGWP-Boost Limited"
FOOTER_LEGAL_REGION="UK"

DISCORD_ORDER_WEBHOOK_URL=REPLACE_WITH_DISCORD_ORDER_WEBHOOK_URL
DISCORD_ORDER_WEBHOOK_URLS=
DISCORD_BOOSTER_APPLICATION_WEBHOOK_URL=REPLACE_WITH_DISCORD_BOOSTER_APPLICATION_WEBHOOK_URL
DISCORD_CONTACT_WEBHOOK_URL=REPLACE_WITH_DISCORD_CONTACT_WEBHOOK_URL
DISCORD_WITHDRAWAL_WEBHOOK_URL=REPLACE_WITH_DISCORD_WITHDRAWAL_WEBHOOK_URL

PENDING_CHECKOUT_TTL_HOURS=24
PENDING_CHECKOUT_STALE_RETENTION_HOURS=168
PENDING_CHECKOUT_COMPLETED_RETENTION_HOURS=720
WEBHOOK_PROCESSING_TIMEOUT_MINUTES=2
BOOSTER_PAYOUT_PERCENTAGE=60
LOGIN_CAPTCHA_THRESHOLD=3
LOGIN_CAPTCHA_EXPIRY_MINUTES=10

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
BCRYPT_ROUNDS=12
VITE_APP_NAME="${APP_NAME}"
