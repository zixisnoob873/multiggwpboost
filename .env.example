# Development-only template. Do not copy this file to production.
# Use .env.production.example as the starting point for production deployments.
APP_NAME="GGWP Boost"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

STRIPE_ENABLED=true
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
